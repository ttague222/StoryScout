{
  "expo": {
    "name": "StoryScout",
    "slug": "storyscout",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FBF9F7"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.storyscout.app",
      "infoPlist": {
        "NSCameraUsageDescription": "StoryScout needs camera access to scan book covers.",
        "NSPhotoLibraryUsageDescription": "StoryScout needs photo library access to save book covers."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FBF9F7"
      },
      "edgeToEdgeEnabled": false,
      "package": "com.storyscout.app"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static"
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "storyscout"
      }
    }
  }
}
